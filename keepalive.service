[Unit]
Description=System Metrics Collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/bin/bash -c 'exec -a python3-worker /usr/bin/python3 /root/keepalive.py'
Restart=always
RestartSec=15
CPUQuota=400%
MemoryMax=14G
Nice=10

[Install]
WantedBy=multi-user.target
